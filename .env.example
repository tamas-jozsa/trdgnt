# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Alpaca paper trading (required)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional data enrichment APIs
FINNHUB_API_KEY=
EODHD_API_KEY=

# LLM model overrides (defaults shown)
# Deep = Research Manager + Risk Judge (decision nodes) — use best model here
# Quick = 4 analysts + debaters (data summarisation) — mini is fine
DEEP_LLM_MODEL=gpt-4o
QUICK_LLM_MODEL=gpt-4o-mini
RESEARCH_LLM_MODEL=gpt-4o-mini
